.env
# AI模型缓存
model_cache/

# Python虚拟环境和缓存
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
.Python
*.egg-info/
dist/
build/

# 报告目录（自动生成，默认忽略）
reports/*

# 分析报告目录（完全忽略，不提交到远端）
reports/analysis/

# IDE和编辑器
.vscode/
.idea/
*.swp
*.swo
*~

# Pytest 缓存目录（放在 tests 下）
tests/.pytest_cache/

# 测试结果和待办文件（本地调试用）
tests/testResult.txt
tests/testResult2.txt
tests/todoList.txt
tests/language_support_test_report.json

# BigVul测试数据集（大型文件，不提交到远端）
tests/BigVul/

# SQLite 运行时数据库文件
infrastructure/database/*.db
infrastructure/database/*.sqlite
infrastructure/database/*.sqlite3
infrastructure/database/*.db-*
infrastructure/database/*.db-journal
infrastructure/database/*.db-wal

# 专利资料目录
专利/